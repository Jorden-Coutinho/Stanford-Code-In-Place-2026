def main():
    put_beeper() #to put the first beeper since idw overlap by doing this in the fill row
    while left_is_clear(): #here left checks for the top so that this doesnt ruin a 1x1 world
        fill_row() #pretty simple, puts beepers in alternate spacing
        move_up() #very simple, moves up a row
    fill_row() #fencepost bug at the top row
    end_position() #returns karel to required position

def fill_row(): 
    while front_is_clear(): #while loop bcz idk how many times
        if front_is_clear(): #if loop because idw karel to get hurt by banging his head
            move()
            if front_is_clear():
                move()
                put_beeper()

def move_up():
    flip() #teddy west-side
    bull() #charges to wall
    if beepers_present(): #to alternate patterns in rows
        turn_right()
        move() #to skip the first column 
        turn_right()
        if front_is_clear():
            move()
            put_beeper()
    else: #basically checks for odd or even rows
        turn_right()
        move()
        turn_right()
        put_beeper()

def end_position(): #just to satisfy the puzzles requirements
    flip()
    bull()
    turn_left()
    bull()
    turn_left()

def bull():
    while front_is_clear():
        move()

def turn_right():
    for i in range(3):
        turn_left()

def flip():
    turn_left()
    turn_left()

